{
  "name": "learning-garden-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "dev:stop": "node scripts/kill-dev-ports.mjs",
    "dev:clean": "pnpm dev:stop && rm -rf .next && pnpm dev",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1 --port 3100",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "next typegen && tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@codemirror/lang-javascript": "6.2.5",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/lang-python": "6.2.1",
    "@tiptap/core": "3.23.5",
    "@tiptap/extension-code-block": "3.23.5",
    "@tiptap/react": "3.23.5",
    "@tiptap/starter-kit": "3.23.5",
    "@types/katex": "0.16.8",
    "codemirror": "6.0.2",
    "katex": "0.16.47",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "prettier": "3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.6"
  }
}
